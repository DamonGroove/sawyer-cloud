# customization/customers/example-customer/customer.env
#
# Example customer folder demonstrating the full shape a real customer.env
# takes. Real customers are created by the operator per CLAUDE.md §3.14
# (copy a flavor folder, edit customer.env, `mgmt-ctl enroll`).
#
# This file is tracked. Secrets go in customer.env.secret.age — see
# customer.env.secret.age.example next to this file.

CUSTOMER_NAME=example-customer
CUSTOMER_FLAVOR=default
CUSTOMER_DOMAIN=example.sawyer-cloud.internal

# --- branding (overrides flavor defaults) ----------------------------------
CUSTOMER_DISPLAY_NAME=Example Customer Cloud
CUSTOMER_SLOGAN=Private cloud for Example Customer, Inc.
CUSTOMER_URL=https://example.sawyer-cloud.internal
CUSTOMER_PRIMARY_COLOR=#2A6F97
CUSTOMER_IMPRINT_URL=https://example.sawyer-cloud.internal/imprint
CUSTOMER_PRIVACY_URL=https://example.sawyer-cloud.internal/privacy

# --- community containers (CLAUDE.md §3.5, §3.6) ---------------------------
# customer-agent is always on (added by the compose overlay). Turning on
# other community containers (from §3.5 upstream allow-list or §3.6 custom
# allow-list) goes here as a space-separated list.
AIO_COMMUNITY_CONTAINERS=

# --- Nextcloud app overrides (CLAUDE.md §3.7) ------------------------------
# Extra apps beyond whatever the flavor provides. This is additive.
NEXTCLOUD_EXTRA_APPS=
# Apps to uninstall (removed from the flavor default set for this customer).
NEXTCLOUD_REMOVE_APPS=

# --- AI (CLAUDE.md §3.10) --------------------------------------------------
# Leave AI_PROVIDER unset to skip. Valid: localai | ollama | openai | litellm.
# AI_PROVIDER=openai
# AI_ENDPOINT_URL=https://api.openai.com/v1
# AI_DEFAULT_MODEL=gpt-4o
# AI_API_KEY → customer.env.secret.age

# --- Cloudflare Tunnel (CLAUDE.md §3.1) ------------------------------------
ENABLE_CLOUDFLARE_TUNNEL=false
# CLOUDFLARE_TUNNEL_TOKEN → customer.env.secret.age

# --- Exchange EWS (CLAUDE.md §3.9) -----------------------------------------
ENABLE_EXCHANGE_INTEGRATION=false
# EXCHANGE_DEFAULT_HOST=mail.example.com

# --- management server registration ----------------------------------------
MGMT_SERVER_URL=https://mgmt.sawyer-cloud.internal
# MGMT_REGISTRATION_TOKEN → customer.env.secret.age (one-time, issued by
# `mgmt-ctl enroll example-customer`, consumed on first agent register).
