# customization/flavors/law-firm/flavor.env
#
# Conservative defaults tuned for legal-sector customers. Emphasis on
# document review, matter-centric collaboration, and strong access
# controls. Does NOT enable AI features by default — law firms tend to
# gate AI use on their own policy review.

CUSTOMER_FLAVOR=law-firm
CUSTOMER_SLOGAN=Your practice, privately hosted.
CUSTOMER_PRIMARY_COLOR=#5B2E91

# --- Nextcloud apps (CLAUDE.md §3.7) ---------------------------------------
# Richer: Collabora for in-browser docx/xlsx editing; files_external for
# SMB-mounted case archives; integration_ews for Outlook-backed calendars;
# audit for the compliance trail; terms_of_service for click-through NDA.
NEXTCLOUD_EXTRA_APPS=calendar contacts deck notes tasks spreed files_external richdocuments integration_ews audit terms_of_service files_retention

# --- AIO tunables -----------------------------------------------------------
# Law firms tend to exchange large PDF packets. Upload ceiling raised.
NEXTCLOUD_UPLOAD_LIMIT=32G
NEXTCLOUD_MAX_TIME=7200
NEXTCLOUD_MEMORY_LIMIT=1024M

# --- feature defaults -------------------------------------------------------
# EWS is commonly needed; default on. Individual customers still have to
# populate EXCHANGE_DEFAULT_HOST and per-user credentials.
ENABLE_EXCHANGE_INTEGRATION=true
ENABLE_CLOUDFLARE_TUNNEL=false

# --- AI off by default; customer can opt in --------------------------------
# AI_PROVIDER unset → bootstrap.sh skips configure_ai.

# --- Alpine packages (CLAUDE.md §3.12) -------------------------------------
# Tesseract for PDF OCR on scanned filings; poppler-utils for text
# extraction from generated PDFs (both on the allow-list).
NEXTCLOUD_ADDITIONAL_APKS=imagemagick ghostscript poppler-utils tesseract-ocr tesseract-ocr-data-eng

# --- management server ------------------------------------------------------
AGENT_TICK_INTERVAL_SECONDS=20
