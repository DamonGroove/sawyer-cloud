# customization/flavors/default/flavor.env
#
# Defaults shared by every customer on the "default" flavor. Customer-level
# values in customer.env override anything here. This file is tracked;
# NEVER put secrets here — they go in customer.env.secret.age.

# --- branding defaults (customer.env typically overrides all of these) -----
CUSTOMER_FLAVOR=default
CUSTOMER_SLOGAN=Your private cloud, hosted by us.
CUSTOMER_PRIMARY_COLOR=#006AA7

# --- Nextcloud apps (CLAUDE.md §3.7) ---------------------------------------
# Installed and enabled on every customer of this flavor unless removed via
# NEXTCLOUD_REMOVE_APPS in the customer's env.
NEXTCLOUD_EXTRA_APPS=calendar contacts deck notes tasks spreed files_external

# --- AIO tunables (CLAUDE.md §3.11) ----------------------------------------
NEXTCLOUD_UPLOAD_LIMIT=16G
NEXTCLOUD_MAX_TIME=3600
NEXTCLOUD_MEMORY_LIMIT=512M

# --- features off by default; flip on in customer.env ----------------------
ENABLE_CLOUDFLARE_TUNNEL=false
ENABLE_EXCHANGE_INTEGRATION=false

# --- management server ------------------------------------------------------
AGENT_TICK_INTERVAL_SECONDS=20
